{
  "name": "elizon-mobile",
  "version": "0.8.5",
  "description": "elizon desktop client",
  "author": "elizon",
  "repository": {
    "type": "git",
    "url": "https://github.com/elizonapp/ignite-mobile.git"
  },
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "NODE_ENV=production bun src/index.ts",
    "build": "bun run build.ts",
    "icons:desktop": "bun scripts/prepare-app-icons.mjs",
    "desktop:dev": "bun run build && electron .",
    "desktop:run": "bun run build && electron .",
    "desktop:build": "bun run build && bun run icons:desktop && electron-builder",
    "desktop:build:win": "bun run build && bun run icons:desktop && electron-builder --win",
    "desktop:build:win:builder": "bun run build && bun run icons:desktop && electron-builder --win",
    "desktop:build:win:portable": "bun run build && bun run icons:desktop && electron-builder --win portable",
    "desktop:build:mac": "bun run build && bun run icons:desktop && electron-builder --mac",
    "desktop:build:linux": "bun run build && bun run icons:desktop && electron-builder --linux"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/ios": "^8.4.2",
    "@radix-ui/react-label": "^2.1.13",
    "@radix-ui/react-select": "^2.3.5",
    "@radix-ui/react-slot": "^1.3.1",
    "bun-plugin-tailwind": "^0.1.2",
    "capacitor-secure-storage-plugin": "^0.13.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.26.0",
    "novnc-next": "^1.0.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "electron-builder-squirrel-windows": "26.15.3",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "app.elizon.ignite.mobile",
    "productName": "elizon",
    "artifactName": "ignite-desktop-${version}.${ext}",
    "forceCodeSigning": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.png",
      "signExecutable": false
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/electron-updater/**",
      "node_modules/builder-util-runtime/**",
      "node_modules/semver/**",
      "node_modules/sax/**",
      "node_modules/lazy-val/**",
      "node_modules/tiny-typed-emitter/**",
      "node_modules/lodash.escaperegexp/**",
      "node_modules/lodash.isequal/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "elizonapp",
        "repo": "ignite-mobile",
        "releaseType": "release"
      }
    ],
    "mac": {
      "target": ["dmg"],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "build/icon.png",
      "category": "Network"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "ignite-desktop-setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "ignite-desktop-portable-${version}.${ext}"
    }
  },
  "overrides": {
    "js-yaml": "4.3.0",
    "form-data": "4.0.6",
    "tmp": "0.2.7",
    "@xmldom/xmldom": "0.8.13",
    "@tootallnate/once": "2.0.1",
    "ip-address": "10.2.0",
    "tar": "7.5.20",
    "electron-builder-squirrel-windows": "26.15.3",
    "shell-quote": "1.10.0",
    "fast-uri": "3.1.4"
  }
}
