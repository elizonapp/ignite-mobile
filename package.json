{
  "name": "elizon-mobile",
  "version": "0.8.2",
  "description": "elizon desktop client",
  "author": "elizon",
  "repository": {
    "type": "git",
    "url": "https://github.com/elizonapp/ignite-mobile.git"
  },
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "NODE_ENV=production bun src/index.ts",
    "build": "bun run build.ts",
    "icons:desktop": "bun scripts/prepare-desktop-icons.mjs",
    "desktop:dev": "bun run build && electron .",
    "desktop:run": "bun run build && electron .",
    "desktop:build": "bun run build && bun run icons:desktop && electron-builder",
    "desktop:build:win": "bun run build && bun run icons:desktop && bunx --bun electron-packager . elizon --platform=win32 --arch=x64 --out=release --overwrite --prune=true --app-bundle-id=app.elizon.ignite.mobile",
    "desktop:build:win:portable": "bun run build && bun run icons:desktop && electron-builder --win portable",
    "desktop:build:win:builder": "bun run build && bun run icons:desktop && electron-builder --win",
    "desktop:build:mac": "bun run build && bun run icons:desktop && electron-builder --mac",
    "desktop:build:linux": "bun run build && bun run icons:desktop && electron-builder --linux"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "bun-plugin-tailwind": "^0.1.2",
    "capacitor-secure-storage-plugin": "^0.13.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.545.0",
    "novnc-next": "^1.0.0",
    "react": "^19",
    "react-dom": "^19",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.0.0",
    "electron": "^41.2.1",
    "electron-builder": "^25.0.0",
    "electron-packager": "^17.0.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.4.0"
  },
  "build": {
    "appId": "app.elizon.ignite.mobile",
    "productName": "elizon",
    "artifactName": "ignite-mobile-${version}.${ext}",
    "forceCodeSigning": false,
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "build/icon.png",
      "sign": false
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "target": ["dmg"],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "build/icon.png",
      "category": "Network"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "ignite-mobile-setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "ignite-mobile-portable-${version}.${ext}"
    }
  }
}
